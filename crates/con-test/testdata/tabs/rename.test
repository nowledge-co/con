# tabs/rename.test
# Tab rename: set and clear user label.

cmd --json tabs list  # initial state has tab 1
---- json-subset
{"tabs":[{"index":1}]}

cmd --json tabs list  # tab 1 has no user label initially
---- contains
"user_label":null

cmd --json tabs list  # tab 1 is active
---- json-subset
{"tabs":[{"index":1,"is_active":true}]}
